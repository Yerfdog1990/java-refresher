<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="All Test Suite" thread-count="3" parallel="tests">
    <test name="chrome-test">
        <parameter name="os" value="macOS"/>
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="day51.test_cases.TC001AccountRegistrationTest">
                <methods>
                    <include name="givenWebpage_whenRegisterNewCount_theSuccess"/>
                </methods>
            </class>
            <class name="day51.test_cases.TC002AccountLoginTest">
                <methods>
                    <include name="givenWebpage_whenLogin_theSuccess"/>
                </methods>
            </class>
            <class name="day51.test_cases.TC003LoginDataDrivenTest">
                <methods>
                    <include name="givenWebpage_whenLogin_thenVerify"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="firefox-test">
        <parameter name="os" value="macOS"/>
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="day51.test_cases.TC001AccountRegistrationTest">
                <methods>
                    <include name="givenWebpage_whenRegisterNewAccount_theSuccess"/>
                </methods>
            </class>
            <class name="day51.test_cases.TC002AccountLoginTest">
                <methods>
                    <include name="givenWebpage_whenLogin_theSuccess"/>
                </methods>
            </class>
            <class name="day51.test_cases.TC003LoginDataDrivenTest">
                <methods>
                    <include name="givenWebpage_whenLogin_thenVerify"/>
                </methods>
            </class>
        </classes>
    </test>

    <test name="safari-test">
        <parameter name="os" value="safari"/>
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="day51.test_cases.TC001AccountRegistrationTest">
                <methods>
                    <include name="givenWebpage_whenRegisterNewCount_theSuccess"/>
                </methods>
            </class>
            <class name="day51.test_cases.TC002AccountLoginTest">
                <methods>
                    <include name="givenWebpage_whenLogin_theSuccess"/>
                </methods>
            </class>
            <class name="day51.test_cases.TC003LoginDataDrivenTest">
                <methods>
                    <include name="givenWebpage_whenLogin_thenVerify"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>