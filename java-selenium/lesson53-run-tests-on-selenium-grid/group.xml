            <class name="day53.test_cases.TC002AccountLoginTest">
                <methods>
                    <include name="givenWebpage_whenLogin_theSuccess"/>
                </methods>
            </class>
<!--            <class name="day53.test_cases.TC003LoginDataDrivenTest">-->
<!--                <methods>-->
<!--                    <include name="givenWebpage_whenLogin_thenVerify"/>-->
<!--                </methods>-->
<!--            </class>-->
        </classes>
    </test>

    <test name="safari-test">
        <parameter name="os" value="mac"/>
        <parameter name="os" value="windows"/>
        <parameter name="os" value="linux"/>
        <parameter name="browser" value="safari"/>
        <classes>
            <class name="day53.test_cases.TC001AccountRegistrationTest">
                <methods>
                    <include name="givenWebpage_whenRegisterNewAccount_theSuccess"/>
